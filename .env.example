# Server
PORT=3000
NODE_ENV=development

# Bitcoin network: "signet" or "testnet"
BITCOIN_NETWORK=signet

# Test private key (WIF format, testnet) - used by test-message-signing.js
# Generate one with: node -e "const {generateKeyPair}=require('./bitcoin-transaction-poc'); console.log(generateKeyPair().toWIF())"
TEST_PRIVATE_KEY_WIF=
